{
  "name": "cubescraft-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Employee Task Tracking System - Production Ready Frontend",
  "author": "cubescraft",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build --analyze",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{jsx,js,css}\"",
    "start": "npm run preview"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "i18next": "^26.0.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead"
  ]
}
